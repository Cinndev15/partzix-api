# Server Configuration
PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=partzix_db
DB_PORT=3306

# Mail Configuration (SMTP)
# For development/testing, you can use Mailtrap or similar services.
# If these variables are not configured, the API will output verification codes to the console/logs.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Partzix <soporte@partzix.com>"
